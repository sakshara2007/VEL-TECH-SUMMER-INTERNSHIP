      "source": [
        "# Initialize the Logistic Regression model\n",
        "model = LogisticRegression(solver='liblinear', random_state=42)\n",
        "\n",
        "# Train the model\n",
        "model.fit(X_train_tfidf, y_train)\n",
        "\n",
        "print(\"Logistic Regression model trained successfully!\")"
